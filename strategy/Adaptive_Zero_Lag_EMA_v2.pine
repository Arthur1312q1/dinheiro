//@version=3
strategy(title="Adaptive Zero Lag EMA v2", shorttitle="AZLEMA", overlay = true, initial_capital=1000, currency="USD", commission_type=strategy.commission.percent, commission_value=0, slippage = 0, pyramiding=1, calc_on_every_tick=false)

src = input(title="Source", type=source, defval=close)
secType = input(title="Security Type", options=["Forex", "Metal Spot", "Cryptocurrency","Custom"], defval="Metal Spot")
contracts = input(title="Custom # of Contracts", defval=500, step=1)
limit = input(title="Max Lots", type=integer, defval=100)
Period = input(title="Period", type=integer, defval = 20)
adaptive = input(title="Adaptive Method", options=["Off", "Cos IFM", "I-Q IFM", "Average"], defval="Cos IFM")
GainLimit = input(title="Gain Limit", type=integer, defval = 900)
Threshold = input(title="Threshold", type = float, defval=0, step=0.01)
fixedSL = input(title="SL Points", defval=2000)
fixedTP = input(title="TP Points", defval=55)
risk = input(title='Risk', defval=0.01, step=0.01)


range = 50 //input(title="Max Period", type=integer, defval=60, minval=8, maxval=100)

PI = 3.14159265359
lenIQ = 0.0
lenC = 0.0

//##############################################################################
//I-Q IFM
//##############################################################################
if(adaptive=="I-Q IFM" or adaptive=="Average")
    imult = 0.635
    qmult = 0.338
    inphase = 0.0
    quadrature = 0.0
    re = 0.0
    im = 0.0
    deltaIQ = 0.0
    instIQ = 0.0
    V = 0.0
    
    P = src - src[7]
    inphase := 1.25*(P[4] - imult*P[2]) + imult*nz(inphase[3])
    quadrature := P[2] - qmult*P + qmult*nz(quadrature[2])
    re := 0.2*(inphase*inphase[1] + quadrature*quadrature[1]) + 0.8*nz(re[1])
    im := 0.2*(inphase*quadrature[1] - inphase[1]*quadrature) + 0.8*nz(im[1])
    if (re!= 0.0)
        deltaIQ := atan(im/re)
    for i=0 to range
        V := V + deltaIQ[i]
        if (V > 2*PI and instIQ == 0.0)
            instIQ := i
    if (instIQ == 0.0)
        instIQ := nz(instIQ[1])
    lenIQ := 0.25*instIQ + 0.75*nz(lenIQ[1])

//##############################################################################
//COSINE IFM
//##############################################################################
if(adaptive == "Cos IFM" or adaptive == "Average")
    s2 = 0.0
    s3 = 0.0
    deltaC = 0.0
    instC = 0.0
    v1 = 0.0
    v2 = 0.0
    v4 = 0.0
    
    v1 := src - src[7]
    s2 := 0.2*(v1[1] + v1)*(v1[1] + v1) + 0.8*nz(s2[1])
    s3 := 0.2*(v1[1] - v1)*(v1[1] - v1) + 0.8*nz(s3[1])
    if (s2 != 0)
        v2 := sqrt(s3/s2)
    if (s3 != 0)
        deltaC := 2*atan(v2)
    for i = 0 to range
        v4 := v4 + deltaC[i]
        if (v4 > 2*PI and instC == 0.0)
            instC := i - 1
    if (instC == 0.0)
        instC := instC[1]
    lenC := 0.25*instC + 0.75*nz(lenC[1])

if (adaptive == "Cos IFM")
    Period := round(lenC)
if (adaptive == "I-Q IFM")
    Period := round(lenIQ)
if (adaptive == "Average")
    Period := round((lenC + lenIQ)/2)

//##############################################################################
//ZERO LAG EXPONENTIAL MOVING AVERAGE
//##############################################################################
LeastError = 1000000.0
EC = 0.0
Gain = 0.0
EMA = 0.0
Error = 0.0
BestGain = 0.0

alpha =2/(Period + 1)
EMA := alpha*src + (1-alpha)*nz(EMA[1])

for i = -GainLimit to GainLimit
    Gain := i/10
    EC := alpha*(EMA + Gain*(src - nz(EC[1]))) + (1 - alpha)*nz(EC[1])
    Error := src - EC
    if(abs(Error)<LeastError)
        LeastError := abs(Error)
        BestGain := Gain

EC := alpha*(EMA + BestGain*(src - nz(EC[1]))) + (1-alpha)*nz(EC[1])

plot(EC, title="EC", color=orange, linewidth=2)
plot(EMA, title="EMA", color=red, linewidth=2)

//##############################################################################
//LÓGICA DE TRADE - VERSÃO CORRIGIDA SEM TRADES FANTASMA
//##############################################################################

// SINAIS RAW calculados na barra atual (ainda NÃO confirmados)
buy_signal = crossover(EC,EMA) and 100*LeastError/src > Threshold
sell_signal = crossunder(EC,EMA) and 100*LeastError/src > Threshold

// ============================================================================
// FLAGS PERSISTENTES (compatível Pine v3 - sem usar 'var')
// ============================================================================
// MODIFICAÇÃO 1: Criação de flags que persistem entre barras usando nz()[1]
// Estas flags armazenam sinais pendentes de execução
pendingBuy = false
pendingSell = false

// Preservar valor anterior da flag (persistência entre barras)
pendingBuy := nz(pendingBuy[1])
pendingSell := nz(pendingSell[1])

// ============================================================================
// CONFIRMAÇÃO DE SINAIS - DELAY DE 1 BARRA (elimina repainting)
// ============================================================================
// MODIFICAÇÃO 2: Sinais só são marcados se ocorreram na BARRA ANTERIOR [1]
// Isso garante que apenas sinais CONFIRMADOS (após fechamento) sejam executados
if (buy_signal[1])
    pendingBuy := true
    // DEBUG: plotshape(true, style=shape.labelup, location=location.belowbar, color=green, text="BUY PEND", textcolor=white, size=size.tiny, transp=0)

if (sell_signal[1])
    pendingSell := true
    // DEBUG: plotshape(true, style=shape.labeldown, location=location.abovebar, color=red, text="SELL PEND", textcolor=white, size=size.tiny, transp=0)

// ============================================================================
// CÁLCULO DE POSIÇÃO E LOTES - CORRIGIDO PARA CRIPTO REAL
// ============================================================================
// CORREÇÃO FINANCEIRA #1: Eliminado secScaler que inflava artificialmente os valores
// Agora calcula quantidade de moedas baseado no valor USDT real da posição
balance = strategy.initial_capital + strategy.netprofit

// ============================================================================
// EXECUÇÃO ATÔMICA DE ORDENS (elimina trades fantasma)
// ============================================================================
if (time>timestamp(2016, 1, 1 , 0, 0) and balance > 0)
    
    // CORREÇÃO FINANCEIRA #2: Cálculo de quantidade baseado em USDT real
    // Fórmula: (Risk% × Balance) / Stop Loss em USDT = quantidade em moedas
    // Exemplo: (1% × $1000) / ($2 SL) = 5 moedas
    // Lucro por ponto agora será: quantidade × variação de preço em USDT
    riskAmount = risk * balance
    stopLossUSDT = fixedSL * syminfo.mintick
    lots = riskAmount / stopLossUSDT
    
    // Aplicar limite máximo se configurado
    maxQty = limit
    lots := lots > maxQty ? maxQty : lots
    
    // ========================================================================
    // ENTRADA LONG (BUY)
    // ========================================================================
    // MODIFICAÇÃO 3: Verificação atômica de position_size ANTES de enviar ordem
    // - Só executa se pendingBuy=true E (flat ou short)
    // - OCA removido para evitar cancelamentos implícitos
    // - Flag zerada IMEDIATAMENTE após envio da ordem
    // - Mensagens customizadas para integração com webhook BingX
    if (pendingBuy and strategy.position_size <= 0)
        // DEBUG: plotshape(true, style=shape.triangleup, location=location.belowbar, color=lime, text="BUY", textcolor=white, size=size.small, transp=0)
        strategy.entry("BUY", strategy.long, qty=lots, comment="ENTER-LONG_BingX_ETH-USDT_trade_45M_9640193738b8e54a44f2e5c7")
        strategy.exit("B.Exit", "BUY", qty_percent = 100, loss=fixedSL, trail_offset=15, trail_points=fixedTP, comment="EXIT-LONG_BingX_ETH-USDT_trade_45M_9640193738b8e54a44f2e5c7")
        pendingBuy := false  // MODIFICAÇÃO 4: Limpa flag após execução (1 ordem por sinal)
    
    // ========================================================================
    // ENTRADA SHORT (SELL)
    // ========================================================================
    // MODIFICAÇÃO 3: Verificação atômica de position_size ANTES de enviar ordem
    // - Só executa se pendingSell=true E (flat ou long)
    // - OCA removido para evitar cancelamentos implícitos
    // - Flag zerada IMEDIATAMENTE após envio da ordem
    // - Mensagens customizadas para integração com webhook BingX
    if (pendingSell and strategy.position_size >= 0)
        // DEBUG: plotshape(true, style=shape.triangledown, location=location.abovebar, color=maroon, text="SELL", textcolor=white, size=size.small, transp=0)
        strategy.entry("SELL", strategy.short, qty=lots, comment="ENTER-SHORT_BingX_ETH-USDT_trade_45M_9640193738b8e54a44f2e5c7")
        strategy.exit("S.Exit", "SELL", qty_percent = 100, loss=fixedSL, trail_offset=15, trail_points=fixedTP, comment="EXIT-SHORT_BingX_ETH-USDT_trade_45M_9640193738b8e54a44f2e5c7")
        pendingSell := false  // MODIFICAÇÃO 4: Limpa flag após execução (1 ordem por sinal)

//##############################################################################
// CORREÇÕES FINANCEIRAS APLICADAS - SEM ALTERAR LÓGICA DE SINAIS
//##############################################################################
//
// ═══════════════════════════════════════════════════════════════════════════
// PROBLEMA IDENTIFICADO:
// ═══════════════════════════════════════════════════════════════════════════
// O script original usava:
// ❌ commission_type=strategy.commission.cash_per_contract
// ❌ secScaler que multiplicava artificialmente os valores (100000x para Forex)
// ❌ Cálculo: lots = ((risk × balance) / fixedSL) × secScaler
//    → Para Forex: 100000x multiplicador = lucros inflados 100000x
//    → Para Metal Spot: 100x multiplicador = lucros inflados 100x
//
// RESULTADO: Backtesting mostrava milhões de lucro com banca de $1000
//
// ═══════════════════════════════════════════════════════════════════════════
// CORREÇÕES APLICADAS (APENAS ASPECTOS FINANCEIROS):
// ═══════════════════════════════════════════════════════════════════════════
//
// ✅ CORREÇÃO #1 - Commission Type:
//    Antes: commission_type=strategy.commission.cash_per_contract
//    Agora: commission_type=strategy.commission.percent
//    Valor: commission_value=0 (0% = sem comissão)
//    Motivo: TradingView agora calcula comissão como % do valor USDT da posição
//
// ✅ CORREÇÃO #2 - Slippage:
//    Antes: slippage = 5
//    Agora: slippage = 0
//    Motivo: Remover derrapagem para backtesting mais limpo
//
// ✅ CORREÇÃO #3 - Eliminação do secScaler:
//    Removido: secScaler = 100000 (Forex) / 100 (Metal) / 10000 (Crypto)
//    Removido: lots = (...) × secScaler
//    Motivo: Este multiplicador inflava artificialmente o P&L
//
// ✅ CORREÇÃO #4 - Cálculo Realista de Quantidade:
//    Nova fórmula: lots = (risk × balance) / (fixedSL × syminfo.mintick)
//    
//    Exemplo prático com ETH/USDT:
//    - Balance: $1000
//    - Risk: 0.01 (1%)
//    - fixedSL: 2000 pontos
//    - syminfo.mintick: 0.01 (tick mínimo ETH/USDT)
//    
//    Cálculo:
//    riskAmount = 0.01 × 1000 = $10 (risco por trade)
//    stopLossUSDT = 2000 × 0.01 = $20 (stop em USDT)
//    lots = 10 / 20 = 0.5 ETH por trade
//    
//    Se ETH sobe $20: Lucro = 0.5 × 20 = $10 ✓
//    Se ETH cai $20: Perda = 0.5 × 20 = $10 ✓ (1% do balance)
//
// ═══════════════════════════════════════════════════════════════════════════
// O QUE NÃO FOI ALTERADO (GARANTIDO):
// ═══════════════════════════════════════════════════════════════════════════
//
// ✅ Versão: Pine Script v3 (mantida)
// ✅ Cálculo de EC/EMA: 100% preservado (loop GainLimit, alpha, BestGain)
// ✅ Adaptive Methods: Cos IFM, I-Q IFM, Average (inalterados)
// ✅ Sinais: crossover/crossunder logic idêntica
// ✅ Threshold: Filtro de erro mantido exatamente igual
// ✅ Flags: pendingBuy/pendingSell (delay 1 barra preservado)
// ✅ SL/TP: fixedSL=2000, fixedTP=55, trail_offset=15 (inalterados)
// ✅ Webhooks: Comentários BingX preservados palavra por palavra
// ✅ Pyramiding: 1 (sem alteração)
// ✅ Slippage: 0 ticks (modificado)
// ✅ calc_on_every_tick: false (mantido)
//
// ═══════════════════════════════════════════════════════════════════════════
// VALIDAÇÃO PÓS-CORREÇÃO:
// ═══════════════════════════════════════════════════════════════════════════
//
// Compare os resultados antes/depois:
//
// 📊 DEVE PERMANECER IGUAL:
//    ✓ Número total de trades
//    ✓ Preços de entrada exatos
//    ✓ Timestamps de execução
//    ✓ Win Rate %
//    ✓ Profit Factor
//    ✓ Max Drawdown %
//    ✓ Average Win / Average Loss ratio
//
// 💰 DEVE MUDAR (CORREÇÃO):
//    ✓ Net Profit: De milhões → valores realistas ($10-$200 por banca $1000)
//    ✓ Commission paid: 0% (taxa zerada)
//    ✓ Slippage: 0 (derrapagem zerada)
//    ✓ Position size: Quantidade de moedas realista (ex: 0.1-2 ETH)
//
// 🔍 TESTE MANUAL - Exemplo de Trade Esperado:
//    Entrada: 1 ETH @ $3000
//    Stop Loss: $2980 (20 pontos × $1 = $20 de risco)
//    Take Profit: $3010 (10 pontos × $1 = $10 de lucro)
//    Comissão entrada: $0 (taxa 0%)
//    Comissão saída: $0 (taxa 0%)
//    Lucro líquido: $10 ✓
//
// ═══════════════════════════════════════════════════════════════════════════
// NOTAS IMPORTANTES:
// ═══════════════════════════════════════════════════════════════════════════
//
// ⚠️ O script agora reflete a REALIDADE de operar criptomoedas:
//    - Com banca de $1000 e risk 1%, você arrisca $10 por trade
//    - SL de 2000 pontos ($20 em ETH) = position size de 0.5 ETH
//    - Lucros e perdas proporcionais ao movimento de preço real
//    - Sem comissões e sem derrapagem no backtest
//
// ⚠️ Se os lucros ainda parecerem altos:
//    - Verifique o valor de 'fixedSL' (2000 pode ser pequeno demais)
//    - Ajuste 'risk' para 0.005 (0.5%) para ser mais conservador
//    - Confirme que 'syminfo.mintick' está correto para seu ativo
//
// ⚠️ Diferenças esperadas vs trading real:
//    - Backtest não simula: slippage variável, rejeições, liquidez
//    - Use margin mode na exchange que corresponda ao backtest
//    - Teste em paper trading antes de usar capital real
//
//##############################################################################
