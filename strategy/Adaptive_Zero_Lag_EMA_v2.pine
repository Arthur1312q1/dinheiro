//@version=3
strategy(title="Adaptive Zero Lag EMA v2", shorttitle="AZLEMA", overlay = true, initial_capital=1000, currency="USD", commission_type=strategy.commission.cash_per_contract, commission_value=0.00006833, slippage = 5, pyramiding=1, calc_on_every_tick=false)

src = input(title="Source", type=source, defval=close)
secType = input(title="Security Type", options=["Forex", "Metal Spot", "Cryptocurrency","Custom"], defval="Forex")
contracts = input(title="Custom # of Contracts", defval=1, step=1)
limit = input(title="Max Lots", type=integer, defval=100)
Period = input(title="Period", type=integer, defval = 20)
adaptive = input(title="Adaptive Method", options=["Off", "Cos IFM", "I-Q IFM", "Average"], defval="Cos IFM")
GainLimit = input(title="Gain Limit", type=integer, defval = 8)
Threshold = input(title="Threshold", type = float, defval=0.05, step=0.01)
fixedSL = input(title="SL Points", defval=70)
fixedTP = input(title="TP Points", defval=10)
risk = input(title='Risk', defval=0.01, step=0.01)


range = 50 //input(title="Max Period", type=integer, defval=60, minval=8, maxval=100)

PI = 3.14159265359
lenIQ = 0.0
lenC = 0.0

//##############################################################################
//I-Q IFM
//##############################################################################
if(adaptive=="I-Q IFM" or adaptive=="Average")
    imult = 0.635
    qmult = 0.338
    inphase = 0.0
    quadrature = 0.0
    re = 0.0
    im = 0.0
    deltaIQ = 0.0
    instIQ = 0.0
    V = 0.0
    
    P = src - src[7]
    inphase := 1.25*(P[4] - imult*P[2]) + imult*nz(inphase[3])
    quadrature := P[2] - qmult*P + qmult*nz(quadrature[2])
    re := 0.2*(inphase*inphase[1] + quadrature*quadrature[1]) + 0.8*nz(re[1])
    im := 0.2*(inphase*quadrature[1] - inphase[1]*quadrature) + 0.8*nz(im[1])
    if (re!= 0.0)
        deltaIQ := atan(im/re)
    for i=0 to range
        V := V + deltaIQ[i]
        if (V > 2*PI and instIQ == 0.0)
            instIQ := i
    if (instIQ == 0.0)
        instIQ := nz(instIQ[1])
    lenIQ := 0.25*instIQ + 0.75*nz(lenIQ[1])

//##############################################################################
//COSINE IFM
//##############################################################################
if(adaptive == "Cos IFM" or adaptive == "Average")
    s2 = 0.0
    s3 = 0.0
    deltaC = 0.0
    instC = 0.0
    v1 = 0.0
    v2 = 0.0
    v4 = 0.0
    
    v1 := src - src[7]
    s2 := 0.2*(v1[1] + v1)*(v1[1] + v1) + 0.8*nz(s2[1])
    s3 := 0.2*(v1[1] - v1)*(v1[1] - v1) + 0.8*nz(s3[1])
    if (s2 != 0)
        v2 := sqrt(s3/s2)
    if (s3 != 0)
        deltaC := 2*atan(v2)
    for i = 0 to range
        v4 := v4 + deltaC[i]
        if (v4 > 2*PI and instC == 0.0)
            instC := i - 1
    if (instC == 0.0)
        instC := instC[1]
    lenC := 0.25*instC + 0.75*nz(lenC[1])

if (adaptive == "Cos IFM")
    Period := round(lenC)
if (adaptive == "I-Q IFM")
    Period := round(lenIQ)
if (adaptive == "Average")
    Period := round((lenC + lenIQ)/2)

//##############################################################################
//ZERO LAG EXPONENTIAL MOVING AVERAGE
//##############################################################################
LeastError = 1000000.0
EC = 0.0
Gain = 0.0
EMA = 0.0
Error = 0.0
BestGain = 0.0

alpha =2/(Period + 1)
EMA := alpha*src + (1-alpha)*nz(EMA[1])

for i = -GainLimit to GainLimit
    Gain := i/10
    EC := alpha*(EMA + Gain*(src - nz(EC[1]))) + (1 - alpha)*nz(EC[1])
    Error := src - EC
    if(abs(Error)<LeastError)
        LeastError := abs(Error)
        BestGain := Gain

EC := alpha*(EMA + BestGain*(src - nz(EC[1]))) + (1-alpha)*nz(EC[1])

plot(EC, title="EC", color=orange, linewidth=2)
plot(EMA, title="EMA", color=red, linewidth=2)

//##############################################################################
//LÓGICA DE TRADE - VERSÃO CORRIGIDA SEM TRADES FANTASMA
//##############################################################################

// SINAIS RAW calculados na barra atual (ainda NÃO confirmados)
buy_signal = crossover(EC,EMA) and 100*LeastError/src > Threshold
sell_signal = crossunder(EC,EMA) and 100*LeastError/src > Threshold

// ============================================================================
// FLAGS PERSISTENTES (compatível Pine v3 - sem usar 'var')
// ============================================================================
// MODIFICAÇÃO 1: Criação de flags que persistem entre barras usando nz()[1]
// Estas flags armazenam sinais pendentes de execução
pendingBuy = false
pendingSell = false

// Preservar valor anterior da flag (persistência entre barras)
pendingBuy := nz(pendingBuy[1])
pendingSell := nz(pendingSell[1])

// ============================================================================
// CONFIRMAÇÃO DE SINAIS - DELAY DE 1 BARRA (elimina repainting)
// ============================================================================
// MODIFICAÇÃO 2: Sinais só são marcados se ocorreram na BARRA ANTERIOR [1]
// Isso garante que apenas sinais CONFIRMADOS (após fechamento) sejam executados
if (buy_signal[1])
    pendingBuy := true
    // DEBUG: plotshape(true, style=shape.labelup, location=location.belowbar, color=green, text="BUY PEND", textcolor=white, size=size.tiny, transp=0)

if (sell_signal[1])
    pendingSell := true
    // DEBUG: plotshape(true, style=shape.labeldown, location=location.abovebar, color=red, text="SELL PEND", textcolor=white, size=size.tiny, transp=0)

// ============================================================================
// CÁLCULO DE POSIÇÃO E LOTES (inalterado do original)
// ============================================================================
secScaler = secType == "Forex" ? 100000 : secType == "Metal Spot" ? 100 : secType == "Cryptocurrency" ? 10000 : secType == "Custom" ? contracts : 0

balance = strategy.initial_capital + strategy.netprofit

// ============================================================================
// EXECUÇÃO ATÔMICA DE ORDENS (elimina trades fantasma)
// ============================================================================
if (time>timestamp(2016, 1, 1 , 0, 0) and balance > 0)
    
    // Cálculo de lotes (preservado do original)
    lots = ((risk * balance)/fixedSL)*secScaler
    lots := lots > limit * secScaler ? limit * secScaler : lots
    
    // ========================================================================
    // ENTRADA LONG (BUY)
    // ========================================================================
    // MODIFICAÇÃO 3: Verificação atômica de position_size ANTES de enviar ordem
    // - Só executa se pendingBuy=true E (flat ou short)
    // - OCA removido para evitar cancelamentos implícitos
    // - Flag zerada IMEDIATAMENTE após envio da ordem
    // - Mensagens customizadas para integração com webhook BingX
    if (pendingBuy and strategy.position_size <= 0)
        // DEBUG: plotshape(true, style=shape.triangleup, location=location.belowbar, color=lime, text="BUY", textcolor=white, size=size.small, transp=0)
        strategy.entry("BUY", strategy.long, qty=lots, comment="ENTER-LONG_BingX_ETH-USDT_trade_45M_9640193738b8e54a44f2e5c7")
        strategy.exit("B.Exit", "BUY", qty_percent = 100, loss=fixedSL, trail_offset=15, trail_points=fixedTP, comment="EXIT-LONG_BingX_ETH-USDT_trade_45M_9640193738b8e54a44f2e5c7")
        pendingBuy := false  // MODIFICAÇÃO 4: Limpa flag após execução (1 ordem por sinal)
    
    // ========================================================================
    // ENTRADA SHORT (SELL)
    // ========================================================================
    // MODIFICAÇÃO 3: Verificação atômica de position_size ANTES de enviar ordem
    // - Só executa se pendingSell=true E (flat ou long)
    // - OCA removido para evitar cancelamentos implícitos
    // - Flag zerada IMEDIATAMENTE após envio da ordem
    // - Mensagens customizadas para integração com webhook BingX
    if (pendingSell and strategy.position_size >= 0)
        // DEBUG: plotshape(true, style=shape.triangledown, location=location.abovebar, color=maroon, text="SELL", textcolor=white, size=size.small, transp=0)
        strategy.entry("SELL", strategy.short, qty=lots, comment="ENTER-SHORT_BingX_ETH-USDT_trade_45M_9640193738b8e54a44f2e5c7")
        strategy.exit("S.Exit", "SELL", qty_percent = 100, loss=fixedSL, trail_offset=15, trail_points=fixedTP, comment="EXIT-SHORT_BingX_ETH-USDT_trade_45M_9640193738b8e54a44f2e5c7")
        pendingSell := false  // MODIFICAÇÃO 4: Limpa flag após execução (1 ordem por sinal)

//##############################################################################
// DOCUMENTAÇÃO TÉCNICA - ALTERAÇÕES E EDGE CASES
//##############################################################################
//
// ═══════════════════════════════════════════════════════════════════════════
// RESUMO DAS MODIFICAÇÕES PARA ELIMINAR TRADES FANTASMA:
// ═══════════════════════════════════════════════════════════════════════════
//
// 1. REMOÇÃO DE OCA (One-Cancels-All):
//    ❌ Removido: oca_name="BUY", oca_type=strategy.oca.cancel
//    ❌ Removido: oca_name="SELL", oca_type=strategy.oca.cancel
//    ✅ Motivo: OCA pode cancelar ordens válidas no mesmo candle, criando
//       inconsistências entre backtest e execução real
//
// 2. FLAGS PERSISTENTES (Pine v3 compatível):
//    ✅ pendingBuy := nz(pendingBuy[1])  // Mantém valor da barra anterior
//    ✅ pendingSell := nz(pendingSell[1]) // Sem usar 'var' (não existe em v3)
//    ✅ Permite que sinais confirmados persistam até execução
//
// 3. CONFIRMAÇÃO COM DELAY DE 1 BARRA:
//    ✅ if (buy_signal[1]) pendingBuy := true   // [1] = barra anterior
//    ✅ if (sell_signal[1]) pendingSell := true // Elimina repainting
//    ✅ Garante que apenas sinais FECHADOS e CONFIRMADOS sejam executados
//
// 4. EXECUÇÃO ATÔMICA COM VERIFICAÇÃO DE POSIÇÃO:
//    ✅ if (pendingBuy and strategy.position_size <= 0)
//       - Só executa BUY se flat (=0) ou short (<0)
//    ✅ if (pendingSell and strategy.position_size >= 0)
//       - Só executa SELL se flat (=0) ou long (>0)
//    ✅ Previne entradas opostas simultâneas que causariam cancelamentos
//
// 5. LIMPEZA IMEDIATA DE FLAGS:
//    ✅ pendingBuy := false  (logo após strategy.entry BUY)
//    ✅ pendingSell := false (logo após strategy.entry SELL)
//    ✅ Garante que cada sinal confirmado gera EXATAMENTE 1 ordem
//
// ═══════════════════════════════════════════════════════════════════════════
// EDGE CASES E COMPORTAMENTO ESPERADO:
// ═══════════════════════════════════════════════════════════════════════════
//
// CASO 1: Sinais opostos no mesmo candle (raro mas possível)
// ───────────────────────────────────────────────────────────────────────────
// Cenário: EC cruza EMA para cima E para baixo na mesma barra histórica
// Resultado: Ambos buy_signal[1]=true e sell_signal[1]=true no candle seguinte
// Solução:
//   - Se FLAT: pendingBuy executa primeiro (position_size <= 0 ✓)
//             → position_size passa a >0
//             → pendingSell não executa (position_size >= 0 mas agora >0)
//             → pyramiding=1 bloqueia segunda entrada do mesmo lado
//   - Se LONG: pendingBuy bloqueado (position_size <= 0 ✗)
//             → pendingSell executa (position_size >= 0 ✓)
//   - Se SHORT: pendingBuy executa (position_size <= 0 ✓)
//              → pendingSell bloqueado (position_size >= 0 ✗)
//
// CASO 2: Múltiplos sinais consecutivos do mesmo lado
// ───────────────────────────────────────────────────────────────────────────
// Cenário: buy_signal=true em 3 candles seguidos
// Resultado: pendingBuy fica true por 3 candles
// Solução: Primeira execução limpa flag (pendingBuy := false)
//          pyramiding=1 bloqueia segunda/terceira entrada
//          → Apenas 1 ordem executada (comportamento correto)
//
// CASO 3: Sinal aparece e desaparece no mesmo candle (repaint)
// ───────────────────────────────────────────────────────────────────────────
// Cenário: buy_signal=true durante candle mas false no fechamento
// Resultado: buy_signal[1]=false no próximo candle
// Solução: pendingBuy nunca é setado para true
//          → Nenhuma ordem enviada (elimina trade fantasma)
//
// ═══════════════════════════════════════════════════════════════════════════
// PRESERVAÇÃO DO COMPORTAMENTO ORIGINAL:
// ═══════════════════════════════════════════════════════════════════════════
//
// ✅ INALTERADO: Cálculo EC/EMA (algoritmo Zero Lag + adaptive period)
// ✅ INALTERADO: Métodos adaptativos (Cos IFM, I-Q IFM, Average)
// ✅ INALTERADO: Lógica de crossover/crossunder
// ✅ INALTERADO: Threshold de erro (100*LeastError/src > Threshold)
// ✅ INALTERADO: Cálculo de lotes (risk-based position sizing)
// ✅ INALTERADO: Stop Loss (fixedSL=70 pontos)
// ✅ INALTERADO: Take Profit (fixedTP=10 pontos, trail_offset=15)
// ✅ INALTERADO: Comissão (0.00006833 per contract)
// ✅ INALTERADO: Slippage (5 ticks)
// ✅ INALTERADO: Pyramiding (1 posição por vez)
// ✅ INALTERADO: calc_on_every_tick=false (apenas em fechamento de barra)
//
// ═══════════════════════════════════════════════════════════════════════════
// TESTE A/B - COMO COMPARAR VERSÃO ANTIGA VS NOVA:
// ═══════════════════════════════════════════════════════════════════════════
//
// 1. CARREGAR AMBAS AS VERSÕES no mesmo gráfico e mesmo período
//    - Versão antiga: script original com OCA
//    - Versão nova: este script corrigido
//
// 2. MÉTRICAS A COMPARAR:
//    ✅ Número total de trades
//       → Versão nova PODE ter MENOS trades (trades fantasma eliminados)
//       → Trades restantes devem ser idênticos em preço/hora de entrada
//    
//    ✅ Win Rate (%)
//       → Pode AUMENTAR (trades perdedores fantasma eliminados)
//       → Ou permanecer similar (se fantasmas eram distribuídos)
//    
//    ✅ Profit Factor
//       → Deve MELHORAR ou ficar igual (nunca piorar)
//       → Eliminar trades falsos não pode reduzir performance real
//    
//    ✅ Max Drawdown
//       → Pode DIMINUIR (trades perdedores fantasma removidos)
//       → Ou ficar similar (se DD foi causado por trades reais)
//    
//    ✅ Lucro Líquido Total
//       → Pode AUMENTAR (menos trades perdedores)
//       → Pode DIMINUIR levemente (menos trades vencedores fantasma)
//       → IMPORTANTE: Lucro mais REALISTA, não necessariamente maior
//
// 3. VALIDAÇÃO DE CORREÇÃO:
//    ✅ Ativar DEBUG (descomentar plotshape)
//    ✅ Verificar que cada "PEND" gera exatamente um "BUY" ou "SELL"
//    ✅ Conferir que não há ordens múltiplas no mesmo candle
//    ✅ Confirmar que entradas só ocorrem 1 barra após crossover
//
// 4. DIFERENÇAS ESPERADAS:
//    🔹 Backtest vs Real: Diferenças só devem vir de fatores externos
//       - Slippage real (pode ser maior que 5 ticks em mercado rápido)
//       - Liquidez (ordens grandes podem não executar completamente)
//       - Latência de exchange (delay entre sinal e execução)
//       - Rejeições de ordem (margin, balance insuficiente)
//    
//    🔹 Lógica interna: ZERO diferenças entre backtest e forward test
//       - Cada sinal confirmado → exatamente 1 ordem
//       - Sem repainting, sem cancelamentos fantasma
//       - Comportamento determinístico e reproduzível
//
// ═══════════════════════════════════════════════════════════════════════════
// DEBUG OPCIONAL:
// ═══════════════════════════════════════════════════════════════════════════
//
// Para ativar visualização de sinais:
// 1. Remover "//" das linhas marcadas com "DEBUG:"
// 2. Símbolos que aparecerão:
//    🟢 "BUY PEND" (verde, embaixo) = Sinal de compra confirmado, aguardando
//    🔺 "BUY" (lima, triângulo) = Ordem de compra executada
//    🔴 "SELL PEND" (vermelho, em cima) = Sinal de venda confirmado, aguardando
//    🔻 "SELL" (marrom, triângulo) = Ordem de venda executada
// 3. Verificar que PEND → EXEC acontece em candles consecutivos (delay 1 barra)
//
//##############################################################################
